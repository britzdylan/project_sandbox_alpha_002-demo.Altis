#include "ui\defines.hpp"

// ============================================================
// OSF_SquadUI — ODA Personnel Status Board
// IDD 9001
// Controls:  List 9100 | Stats 9300
//            Deploy 9201 | Dismiss 9202 | Loadout 9203 | Close 9200
//
// Vertical layout (safeZoneH multipliers):
//   0.100–0.158  Header zone (olive BG)
//   0.160        Sep
//   0.163–0.700  Roster list
//   0.702        Sep
//   0.706–0.730  Status count bar (IDC 9300)
//   0.732        Sep (green)
//   0.736–0.758  Color legend
//   0.760        Sep
//   0.765–0.799  Action buttons
//   0.856–0.890  Close button
// ============================================================
class OSF_SquadUI
{
    idd = 9001;
    movingEnable = false;
    enableSimulation = false;
    onLoad = "";
    onUnload = "";

    class controlsBackground
    {
        // Main panel — near-black with a faint green tint
        class BG_Main : RscText
        {
            idc = -1;
            x = "safeZoneX + safeZoneW * 0.15";
            y = "safeZoneY + safeZoneH * 0.10";
            w = "safeZoneW * 0.70";
            h = "safeZoneH * 0.80";
            text = "";
            colorBackground[] = {0.04, 0.05, 0.04, 0.97};
        };
        // Header accent — dark olive strip
        class BG_Header : RscText
        {
            idc = -1;
            x = "safeZoneX + safeZoneW * 0.15";
            y = "safeZoneY + safeZoneH * 0.10";
            w = "safeZoneW * 0.70";
            h = "safeZoneH * 0.058";
            text = "";
            colorBackground[] = {0.06, 0.10, 0.06, 1.0};
        };
    };

    class controls
    {
        // ── Header zone ──────────────────────────────────────────────

        // Operation name — small amber label, top-left
